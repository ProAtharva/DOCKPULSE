{
  "name": "dock-pulse",
  "version": "1.0.0",
  "description": "DockPulse — real-time port traffic simulator (Node.js, Redis Pub/Sub, Socket.io)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "client": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "socket.io": "^4.8.0"
  }
}
